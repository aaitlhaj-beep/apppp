# Server Configuration
NODE_ENV=development
PORT=3000

# Session Configuration
SESSION_SECRET=your-super-secret-key-change-this-in-production

# Database Configuration (MongoDB)
# For local development, use: mongodb://localhost:27017/student-management
# For MongoDB Atlas (Cloud), use: mongodb+srv://username:password@cluster.mongodb.net/student-management
MONGODB_URI=mongodb://localhost:27017/student-management

# For Production (Vercel) - use MongoDB Atlas free tier
# Sign up at https://www.mongodb.com/cloud/atlas
# Create a cluster and get your connection string
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/student-management?retryWrites=true&w=majority
